# ========================================
# Mazzi AI - Environment Configuration
# ========================================
# 
# PENTING: Copy file ini ke `.env` dan isi dengan nilai real
# 
# ⚠️ JANGAN COMMIT `.env` ke GitHub!
# Hanya `.env.example` (template kosong) yang di-commit
# 

# Groq API Key (dapatkan dari https://console.groq.com)
# Ganti 'your_actual_key_here' dengan API Key Groq Anda
GROQ_API_KEY=gsk_your_actual_key_here

# Server Configuration
PORT=3000
NODE_ENV=production

# CORS: Domain yang boleh akses (pisah dengan koma)
# Untuk development: http://localhost:3000
# Untuk production: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:3000

# Optional: Provider lain untuk masa depan
FIREWORKS_API_KEY=
TOGETHER_API_KEY=
OPENROUTER_API_KEY=
